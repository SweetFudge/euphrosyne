# ========================
# Serveur
# ========================
server.port=8080

# ========================
# Base de données MySQL
# ========================
spring.datasource.url=jdbc:mysql://localhost:3306/euphrosyne?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=CHANGE_ME
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ========================
# JPA / Hibernate
# ========================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.globally_quoted_identifiers=true
spring.jpa.properties.hibernate.globally_quoted_identifiers_skip_column_definitions=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

# ========================
# JWT
# ========================
app.jwt.secret=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_KEY
app.jwt.expiration=86400000

# ========================
# Admin par défaut
# ========================
app.admin.username=admin
app.admin.password=CHANGE_ME

# ========================
# CORS
# ========================
app.cors.allowed-origins=http://localhost:5173

# ========================
# Email SMTP (décommenter quand serveur prêt)
# ========================
# spring.mail.host=smtp.example.com
# spring.mail.port=587
# spring.mail.username=CHANGE_ME
# spring.mail.password=CHANGE_ME
# spring.mail.properties.mail.smtp.auth=true
# spring.mail.properties.mail.smtp.starttls.enable=true
# app.mail.from=contact@elegance-celebration.fr
# app.mail.from-name=Élégance Célébration

# ========================
# Upload fichiers
# ========================
app.upload.dir=uploads
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
